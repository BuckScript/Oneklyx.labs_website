# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env and fill in REAL values
# ============================================

# NODE ENVIRONMENT
NODE_ENV=production

# ---- SUPABASE (Required) ----
# Get from: Supabase Dashboard > Settings > API > URL and Keys
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (create in Supabase Dashboard > Storage)
SUPABASE_BUCKET=public

# ---- SMTP EMAIL (Optional but recommended) ----
# Without SMTP: emails will not be sent but order will still be saved
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# ---- WHATSAPP (Required) ----
# Indonesia phone: +62 or 08 format, e.g., +6281234567890
WHATSAPP_PHONE_NUMBER=

# ---- GOOGLE SHEETS WEBHOOK (Optional) ----
# If set, orders will be synced to Google Sheets
GOOGLE_SHEETS_WEBHOOK_URL=

# ---- APPLICATION ----
BASE_URL=https://oneklyx.labs
